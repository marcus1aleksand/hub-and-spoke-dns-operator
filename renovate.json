{
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "enabled": true,
      "schedule": [
        "after 9pm on saturday"
      ],
      "matchManagers": [
        "helmv3",
        "dockerfile",
        "pip_requirements",
        "poetry"
      ],
      "additionalBranchPrefix": "{{packageFileDir}}-",
      "groupName": "all-updates"
    }
  ]
}
